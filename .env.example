RAPIDAPI_KEY=your_api_key_here
JSEARCH_API_KEY=your_jsearch_key_here

# Backend SMTP sender (for automated emails: password reset, notifications)
# Legacy config (still supported for backward compatibility)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=your_email@gmail.com

# Production SMTP configuration (recommended for subscription emails)
# Use these in production Render/Vercel environment variables
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=info@ricohunt.com
SMTP_PASSWORD=

# Email sender configuration (for subscription confirmations, payment emails)
EMAIL_FROM=info@ricohunt.com
EMAIL_FROM_NAME=Rico Hunt

# Internal admin email for successful signup notifications
ADMIN_SIGNUP_NOTIFICATION_EMAIL=info@ricohunt.com
ENABLE_SIGNUP_EMAIL_NOTIFICATIONS=true

# Public business inbox (for website contact, footer, support, Stripe, Vercel/Render)
APP_PUBLIC_EMAIL=info@ricohunt.com
SUPPORT_EMAIL=info@ricohunt.com

# Admin login credential — used by auth.py as the env-var fallback when the DB is unreachable.
# Must match the actual admin user's email in Neon. NOT a public contact address.
# In production, set this to your real admin account email in Render dashboard (sync: false).
ADMIN_EMAIL=admin@ricohunt.com

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Option A — bcrypt hash (production):
#   python -c "from passlib.hash import bcrypt; print(bcrypt.hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# Option B — plaintext (development only, ignored when hash is set):
ADMIN_PASSWORD=

# HS256 JWT signing secret (32+ chars):
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_TTL_HOURS=24

# Environment name (production / staging / development)
RICO_ENV=development
APP_ENV=development

# Base URL for password reset emails sent to users
RESET_BASE_URL=https://ricohunt.com

# Set to "true" to log raw reset tokens to console (development only — never enable in production)
RESET_TOKEN_LOG=false

# Emergency fallback: allow env-var credentials when DB is unavailable (incident recovery only)
ALLOW_ENV_AUTH_FALLBACK=false

# Set to "true" behind HTTPS. Production requires true.
COOKIE_SECURE=true

# Optional cookie domain. Production Rico frontend should use:
#   .ricohunt.com
COOKIE_DOMAIN=

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://ricohunt.com,https://www.ricohunt.com

# Comma-separated keywords to hard-exclude from job results
EXCLUDE_KEYWORDS=

# ── Rico AI reasoning + scoring ───────────────────────────────────────────────

# OpenAI API key — powers the conversational reply path in /api/v1/rico/chat
# when the user sends an open-ended message. When unset, Rico falls back to a
# safe templated response. Canonical name expected by the code.
# (Legacy alias OPEN_AI_API is read as a fallback for backwards compatibility.)
OPENAI_API_KEY=
OPEN_AI_API=

# OpenAI model used by RicoOpenAIAgent. Optional. Default: gpt-4.1-mini
RICO_OPENAI_MODEL=gpt-4.1-mini

# DeepSeek API key — current production AI provider (set RICO_AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=

# DeepSeek model selection. Optional. Default: deepseek-chat
DEEPSEEK_MODEL=deepseek-chat
RICO_DEEPSEEK_MODEL=

# DeepSeek API base URL override. Optional. Leave blank to use the default endpoint.
DEEPSEEK_BASE_URL=

# HuggingFace API token — used by src/llm_scorer.py for embedding-based
# semantic job scoring and by src/job_agent.py for HF text generation.
# NOT used in the chat reply path.
# All four aliases below are checked; set whichever your token source provides.
HF_TOKEN=
HF_API_TOKEN=
HF_API_KEY=
HUGGINGFACE_API_KEY=

# ── Jotform onboarding webhook ────────────────────────────────────────────────

# Active Jotform onboarding form ID. The webhook validates submissions against
# this value (comma-separated list also supported).
# JOTFORM_RICO_FORM_ID is an accepted alias for JOTFORM_FORM_ID.
JOTFORM_FORM_ID=
JOTFORM_RICO_FORM_ID=

# Optional shared secret. When set, /api/v1/rico/webhooks/jotform fail-closes
# (returns 403) on missing or wrong secret. Send via header X-Jotform-Signature
# or query param ?secret=...
JOTFORM_WEBHOOK_SECRET=

# Optional Jotform API key for retrieving uploaded CV files. Not required for
# the basic webhook → DB profile flow.
JOTFORM_API_KEY=

# ── Rico AI provider ──────────────────────────────────────────────────────────

# Primary AI provider. Options: deepseek | openai | hf
# Leave unset to auto-detect based on available keys (recommended).
# Set explicitly only to force a specific provider. Production uses deepseek.
RICO_AI_PROVIDER=

# ── Rico safety & automation ─────────────────────────────────────────────────

# Disable auto-apply globally. Keep false unless the apply flow is fully reviewed.
RICO_ENABLE_AUTO_APPLY=false

# Require user confirmation before each application is submitted.
RICO_INTERACTIVE_APPLY=false

# Gate all apply actions behind explicit approval. Strongly recommended in production.
RICO_REQUIRE_APPROVAL_FOR_APPLICATIONS=true

# Send public Telegram alerts (job matches, onboarding events). Disable for staging.
RICO_TELEGRAM_PUBLIC_ALERTS=true

# ── Redis (job queue & rate limiting) ────────────────────────────────────────

# Redis connection URL. Required for background job queue (RQ) and rate limiting.
# WARNING: Do not set to empty string. Leave unset to use default, or set to your Redis URL.
REDIS_URL=redis://localhost:6379/0
# RICO_REDIS_URL=redis://localhost:6379/0

# Hugging Face Inference API token (canonical key name).
# Get one free at: https://huggingface.co/settings/tokens

# Optional: override default models.
# Text generation (default: HuggingFaceH4/zephyr-7b-beta)
HF_TEXT_MODEL=

# Zero-shot classification (default: facebook/bart-large-mnli)
HF_CLASSIFICATION_MODEL=

# Summarization (default: facebook/bart-large-cnn)
HF_SUMMARIZATION_MODEL=

# ── GitHub webhook ────────────────────────────────────────────────────────────

# Secret configured in GitHub repo → Settings → Webhooks.
# When set, POST /api/v1/rico/webhooks/github validates X-Hub-Signature-256
# (HMAC-SHA256). Leave blank in dev to skip signature verification.
GITHUB_WEBHOOK_SECRET=

# ── Billing mode ─────────────────────────────────────────────────────────────

# Controls payment flow. Default: manual (WhatsApp-assisted activation).
# Set to "stripe" to enable Stripe checkout (requires STRIPE_* keys).
BILLING_MODE=manual

# Pricing (AED). Override to change displayed prices without a redeploy.
RICO_PRO_PRICE_AED=29
RICO_PREMIUM_PRICE_AED=49

# ── Stripe (inactive in manual mode; kept for future activation) ──────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_PREMIUM_PRICE_ID=

# ── Legacy ────────────────────────────────────────────────────────────────────

# Legacy control server key (backward compat)
CONTROL_SERVER_API_KEY=

# ── Observability ────────────────────────────────────────────────────────────

# Sentry DSN for error tracking. Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Database Pooling ────────────────────────────────────────────────────────────

# Connection pool tuning (uses psycopg2 ThreadedConnectionPool when present)
DATABASE_POOL_MINCONN=1
DATABASE_POOL_MAXCONN=5
DATABASE_CONNECT_TIMEOUT=10
DATABASE_STATEMENT_TIMEOUT_MS=30000

# ── Zoho Mail API ───────────────────────────────────────────────────────────────

# OAuth 2.0 credentials for Zoho Mail API integration
# Get these from https://api-console.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://mail.zoho.com/integPlatform/connectors/ricomail/v2/redirect

# Optional: Zoho accounts domain (default: accounts.zoho.com, use accounts.zoho.eu for EU)
ZOHO_ACCOUNTS_DOMAIN=

# Zoho Mail Webhook (for future inbox intelligence - real-time email notifications)
# Generate from Zoho Mail Settings → Webhooks
ZOHO_WEBHOOK_URL=
