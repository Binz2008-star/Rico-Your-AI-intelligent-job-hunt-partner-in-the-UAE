# Rico AI — Next.js frontend environment variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local.

# Backend API base URL (no trailing slash)
# Used server-side (SSR) for direct fetch calls (e.g. fetchHealth in dashboard SSR).
# The /proxy rewrite in next.config.js uses this same value for client-side requests.
NEXT_PUBLIC_RICO_API=https://rico-job-automation-api.onrender.com

# Set to "true" to use local mock data instead of live backend calls.
# Only for local development — never set in production.
NEXT_PUBLIC_USE_MOCK=false

# Billing mode. Default: manual (WhatsApp-assisted activation).
# Set to "paddle" to enable Paddle checkout UI (requires backend BILLING_MODE=paddle).
NEXT_PUBLIC_BILLING_MODE=manual

# Rico WhatsApp Business number (no spaces, no +, country code prefix).
# Used for WhatsApp upgrade deep-links in manual billing mode.
NEXT_PUBLIC_RICO_WHATSAPP_NUMBER=971585989080

# Support email shown in manual billing flow
NEXT_PUBLIC_SUPPORT_EMAIL=info@ricohunt.com

# ── Paddle Billing (frontend) ──────────────────────────────────────────────────
# Only set these when NEXT_PUBLIC_BILLING_MODE=paddle. Single-plan scope: Rico Monthly only.
#
# SECURITY: PADDLE_API_KEY is server-side only and must NEVER appear here.
# The keys below are all safe to expose client-side (read-only Paddle.js tokens).
#
# Sandbox client token: Paddle sandbox dashboard → Developer Tools → Authentication
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# true = sandbox (default for local dev), false = production
NEXT_PUBLIC_PADDLE_SANDBOX=true

# Paddle price ID for the single Rico Monthly plan (must match the server-side
# PADDLE_PRO_MONTHLY_PRICE_ID in .env)
NEXT_PUBLIC_PADDLE_PRO_MONTHLY_PRICE_ID=
