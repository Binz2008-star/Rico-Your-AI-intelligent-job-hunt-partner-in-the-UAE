{
    "buildCommand": "npm run build",
    "outputDirectory": ".next",
    "framework": "nextjs",
    "regions": [
        "iad1"
    ],
    "env": {
        "NEXT_PUBLIC_APP_URL": "https://ricohunt.com"
    },
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/proxy/api/:path*",
            "destination": "https://rico-job-automation-api.onrender.com/api/:path*"
        },
        {
            "source": "/proxy/health",
            "destination": "https://rico-job-automation-api.onrender.com/health"
        }
    ]
}
