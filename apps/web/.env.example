# Rico Frontend Environment Variables

# Backend API URL (FastAPI)
# For production: Set to your deployed FastAPI backend URL
# For local development: http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=https://rico-job-automation-api.onrender.com

# Alternative API URL (legacy support)
NEXT_PUBLIC_RICO_API=https://rico-job-automation-api.onrender.com

# Supabase (optional - for future features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Frontend URL (for redirects and callbacks)
NEXT_PUBLIC_APP_URL=https://ricohunt.com
