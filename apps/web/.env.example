# Rico Frontend Environment Variables

# Backend API URL used by Next.js rewrites on the server side.
# Production example:
#   BACKEND_API_BASE_URL=https://api.ricohunt.com
# Local development:
#   BACKEND_API_BASE_URL=http://localhost:8000
BACKEND_API_BASE_URL=https://rico-job-automation-api.onrender.com

# Public API base URL used by client code when needed.
# Production example:
#   NEXT_PUBLIC_API_BASE_URL=https://api.ricohunt.com
# Local development:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=https://rico-job-automation-api.onrender.com

# Supabase (optional - for future features)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Frontend URL (for redirects and callbacks)
NEXT_PUBLIC_APP_URL=https://ricohunt.com
